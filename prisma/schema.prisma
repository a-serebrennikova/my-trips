// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  avatarColor String
  homeCity   String
  trips      Trip[]
  comments   Comment[]
  likes      TripLike[]
}

model Trip {
  id              String   @id @default(cuid())
  userId          String
  title           String
  city            String
  country         String
  startDate       String
  endDate         String
  days            Int
  approximateCost Int
  currency        String
  rating          Int
  coverImage      String
  notes           String?
  createdAt       String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  places          Place[]
  comments        Comment[]
  likes           TripLike[]
}

model Place {
  id     String @id @default(cuid())
  name   String
  city   String
  note   String?
  tripId String
  type   String // "attraction" | "cafe"
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String @id @default(cuid())
  tripId    String
  authorId  String
  message   String
  createdAt String
  trip      Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model TripLike {
  tripId String
  userId String
  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([tripId, userId])
}
